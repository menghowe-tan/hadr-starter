{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hadr/manifest.schema.json",
  "title": "Run manifest — data/manifest.json (PRD §13.2)",
  "type": "object",
  "required": ["schema", "run_utc", "verdict", "changed_event_ids", "feeds"],
  "properties": {
    "schema": { "const": 1 },
    "run_utc": { "type": "string", "format": "date-time" },
    "verdict": { "enum": ["CHANGED", "QUIET"] },
    "changed_event_ids": { "type": "array", "items": { "type": "string" } },
    "feeds": {
      "type": "object",
      "required": ["gdacs", "usgs", "reliefweb"],
      "additionalProperties": {
        "type": "object",
        "required": ["last_success_utc", "status"],
        "properties": {
          "last_success_utc": { "type": ["string", "null"], "format": "date-time" },
          "status": { "enum": ["ok", "stale", "down"] }
        }
      }
    },
    "previous_sitrep_utc": { "type": ["string", "null"], "format": "date-time" },
    "deploy_state": {
      "type": "object",
      "description": "Content hashes of the last deployed views (idempotent deploys).",
      "additionalProperties": { "type": "string" }
    }
  }
}
